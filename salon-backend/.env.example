# Database
# Local example:
DATABASE_URL=postgresql://user:password@localhost:5432/salon_db
# Production example: set this to the Supabase Session mode pooler connection string.

# Auth
JWT_SECRET=your-very-long-random-secret-min-64-chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-salon-app.com

# Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
